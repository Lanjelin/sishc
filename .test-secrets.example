# Copy to .test-secrets for local-only test overrides.
# Remote server hostname used in config and tunnel tests.
SISHC_TEST_REMOTE_SERVER=example.test
# Remote SSH port used in config and tunnel tests.
SISHC_TEST_REMOTE_PORT=2222
# Placeholder IP shown in tunnel-log fixtures.
SISHC_TEST_PUBLIC_IP=198.51.100.10
# Hostname shown in rendered web log lines.
SISHC_TEST_WEB_HOST=example.test
# Subdomain text shown in tunnel-log fixtures.
SISHC_TEST_SUBDOMAIN=sub.example.test
# SSH key path used in config and web form tests.
SISHC_TEST_SSH_KEY=~/.ssh/id_rsa
# Set to true to run the live SSH tunnel smoke test.
SISHC_TEST_LIVE=false
# When true, `go test ./...` includes the live SSH tunnel smoke test.
